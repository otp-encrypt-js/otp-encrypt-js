  "license": "MIT",
  "bugs": {
    "url": "https://github.com/eklem/otp-encrypt-js/issues"
  },
  "homepage": "https://github.com/eklem/otp-encrypt-js#readme",
  "directories": {
    "test": "test"
  },
  "dependencies": {
    "run": "^1.5.0"
  }
}
