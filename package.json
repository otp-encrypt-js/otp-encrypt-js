{
  "name": "otp-encrypt-js",
  "version": "1.0.0",
  "description": "Library of helper-functions for encrypting and decrypting messages with OTPs - One-time pads.",
  "type": "module",
  "main": "./dist/otp-encrypt-js.nodejs.cjs.js",
  "module": "./dist/otp-encrypt-js.nodejs.esm.js",
  "browser": "./dist/otp-encrypt-js.browser.umd.js",
  "scripts": {
    "build": "rollup --config && cp ./dist/*.js* ./demo/",
    "test": "npm run build && standard './scripts/*.js' && cd ./test && npx ava esm.nodejs.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eklem/otp-encrypt-js.git"
  },
  "devDependencies": {
    "ava": "^6.2.0",
    "node-fetch": "^3.3.2",
    "rgi-emoji-regex-pattern": "^1.3.1",
    "unicode-emojis-unique-id-json": "^0.0.9",
    "words-n-numbers": "^9.1.2",
    "rollup": "^4.35.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-commonjs": "^28.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "rollup-plugin-string": "^3.0.0",
    "standard": "^17.1.2"
  },
  "keywords": [
    "otp",
    "one-time-pad-encryption",
    "encryption",
    "decryption",
    "one-time-pad",
    "plaincode",
    "code-table"
  ],
  "author": "Espen Klem",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/eklem/otp-encrypt-js/issues"
  },
  "homepage": "https://github.com/eklem/otp-encrypt-js#readme",
  "directories": {
    "test": "test"
  }
}
